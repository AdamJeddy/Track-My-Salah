    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="2dp">
        <TextView android:id="@+id/cell_21" android:layout_width="0dp" android:layout_height="18dp" android:layout_weight="1" android:layout_margin="1.5dp" android:background="@drawable/cell_none" android:visibility="invisible" /><TextView android:id="@+id/cell_22" android:layout_width="0dp" android:layout_height="18dp" android:layout_weight="1" android:layout_margin="1.5dp" android:background="@drawable/cell_none" android:visibility="invisible" /><TextView android:id="@+id/cell_23" android:layout_width="0dp" android:layout_height="18dp" android:layout_weight="1" android:layout_margin="1.5dp" android:background="@drawable/cell_none" android:visibility="invisible" /><TextView android:id="@+id/cell_24" android:layout_width="0dp" android:layout_height="18dp" android:layout_weight="1" android:layout_margin="1.5dp" android:background="@drawable/cell_none" android:visibility="invisible" /><TextView android:id="@+id/cell_25" android:layout_width="0dp" android:layout_height="18dp" android:layout_weight="1" android:layout_margin="1.5dp" android:background="@drawable/cell_none" android:visibility="invisible" /><TextView android:id="@+id/cell_26" android:layout_width="0dp" android:layout_height="18dp" android:layout_weight="1" android:layout_margin="1.5dp" android:background="@drawable/cell_none" android:visibility="invisible" /><TextView android:id="@+id/cell_27" android:layout_width="0dp" android:layout_height="18dp" android:layout_weight="1" android:layout_margin="1.5dp" android:background="@drawable/cell_none" android:visibility="invisible" />
