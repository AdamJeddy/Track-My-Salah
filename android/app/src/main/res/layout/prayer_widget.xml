<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/header_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/app_name" />

        <TextView
            android:id="@+id/header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Today"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Fajr -->
    <LinearLayout
        android:id="@+id/row_fajr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/name_fajr"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Fajr"
            android:textColor="#374151"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_fajr_jamah"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Jamah"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#16a34a" />

        <Button
            android:id="@+id/btn_fajr_prayed"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:text="Prayed"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#2563eb" />

        <TextView
            android:id="@+id/badge_fajr"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="2"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Dhuhr -->
    <LinearLayout
        android:id="@+id/row_dhuhr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/name_dhuhr"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Dhuhr"
            android:textColor="#374151"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_dhuhr_jamah"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Jamah"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#16a34a" />

        <Button
            android:id="@+id/btn_dhuhr_prayed"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:text="Prayed"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#2563eb" />

        <TextView
            android:id="@+id/badge_dhuhr"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="2"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Asr -->
    <LinearLayout
        android:id="@+id/row_asr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/name_asr"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Asr"
            android:textColor="#374151"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_asr_jamah"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Jamah"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#16a34a" />

        <Button
            android:id="@+id/btn_asr_prayed"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:text="Prayed"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#2563eb" />

        <TextView
            android:id="@+id/badge_asr"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="2"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Maghrib -->
    <LinearLayout
        android:id="@+id/row_maghrib"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/name_maghrib"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Maghrib"
            android:textColor="#374151"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_maghrib_jamah"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Jamah"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#16a34a" />

        <Button
            android:id="@+id/btn_maghrib_prayed"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:text="Prayed"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#2563eb" />

        <TextView
            android:id="@+id/badge_maghrib"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="2"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Isha -->
    <LinearLayout
        android:id="@+id/row_isha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/name_isha"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Isha"
            android:textColor="#374151"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_isha_jamah"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Jamah"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#16a34a" />

        <Button
            android:id="@+id/btn_isha_prayed"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:text="Prayed"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="#2563eb" />

        <TextView
            android:id="@+id/badge_isha"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="2"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp">

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:max="5"
            android:progressTint="#16a34a" />

        <TextView
            android:id="@+id/progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="0/5 done"
            android:textColor="#6b7280"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>
