    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="4dp">
        <TextView android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/cell_complete" android:layout_marginEnd="2dp" />
        <TextView android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/cell_partial" android:layout_marginEnd="2dp" />
        <TextView android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/cell_missed" android:layout_marginEnd="2dp" />
